# ============================================================================
# Modèle de variables d'environnement.
# Copier vers .env.local puis remplir les valeurs. NE JAMAIS committer .env.local
# (secrets réels). Les 🔒 sont des secrets ; les NEXT_PUBLIC_* finissent dans le
# bundle client (publiques par nature).
# ============================================================================

# --- LLM / Chatbot RAG "Jamila" (/api/chat) ---------------------------------
# Fournisseur par défaut du chat : gemini | claude
CHAT_LLM_PROVIDER=gemini
# 🔒 Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# 🔒 Alias accepté (l'un OU l'autre suffit)
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_PROJET=
# 🔒 Anthropic Claude (optionnel — nécessite des crédits API)
ANTHROPIC_API_KEY=

# --- Supabase (base vectorielle RAG + client) -------------------------------
# Publiques (bundle client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Côté serveur / scripts
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=          # 🔒 service_role (bypass RLS)
SUPABASE_JWKS_URL=
SUPABASE_DB_PASSWORD=         # 🔒

# --- Postgres / Prisma (scripts locaux : make embed, make db:query) ---------
# 🔒 Pooler (port 6543, pgbouncer) et connexion directe (port 5432)
DATABASE_URL=
DIRECT_URL=

# --- Firebase (client : authentification) -----------------------------------
# Publiques par conception (identifiants de projet, PAS des secrets)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase (serveur admin : écriture des messages de contact) ------------
# 🔒 JSON du compte de service, ou sa version base64 (recommandé).
# Générer : Firebase Console -> Paramètres -> Comptes de service -> Générer une clé
# Encoder : base64 -i serviceAccount.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT=

# --- hCaptcha (formulaire de contact) ---------------------------------------
# Publique (clé de site). Valeur par défaut = clé de TEST hCaptcha.
NEXT_PUBLIC_HCAPTCHA_SITEKEY=10000000-ffff-ffff-ffff-000000000001
# Activer/désactiver la protection : true | false
NEXT_PUBLIC_HCAPTCHA_ENABLED=true
# 🔒 Secret serveur (siteverify) — dashboard.hcaptcha.com -> Secret Key.
# Valeur par défaut = secret de TEST (à remplacer en prod).
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000

# --- Blog (Medium) ----------------------------------------------------------
# Username Medium pour le flux RSS de la page /blog
NEXT_PUBLIC_MEDIUM_USERNAME=@nkaurelien

# --- Divers -----------------------------------------------------------------
NEXT_PUBLIC_ADMIN_EMAIL=
# Sous-chemin de déploiement (vide pour un domaine racine / Vercel)
NEXT_PUBLIC_BASE_PATH=

# --- Flags optionnels (runtime, pas obligatoires dans le fichier) -----------
# SKIP_ENV_VALIDATION=1   # bypass la validation t3-env (ex. builds Docker)
# REEMBED=1               # force le ré-embedding (make db-reseed)
