generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ContentEntry {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rawMarkdown     String
  slug            String?
  publishDate     DateTime?         @db.Date
  sectionId       String            @db.Uuid
  created_at      DateTime?         @default(now()) @db.Timestamptz(6)
  ContentSection  ContentSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ContentTag      ContentTag[]
  VectorEmbedding VectorEmbedding[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ContentSection {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  category     String
  description  String?
  created_at   DateTime?      @default(now()) @db.Timestamptz(6)
  ContentEntry ContentEntry[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ContentTag {
  contentEntryId String       @db.Uuid
  tagId          String       @db.Uuid
  ContentEntry   ContentEntry @relation(fields: [contentEntryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([contentEntryId, tagId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Profile {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  bioSummary  String
  email       String
  githubUrl   String?
  linkedinUrl String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Tag {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  colorCode  String?
  created_at DateTime?    @default(now()) @db.Timestamptz(6)
  ContentTag ContentTag[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model VectorEmbedding {
  id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  textChunk       String
  embeddingVector Unsupported("vector")?
  contentEntryId  String                 @db.Uuid
  created_at      DateTime?              @default(now()) @db.Timestamptz(6)
  ContentEntry    ContentEntry           @relation(fields: [contentEntryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model content_entries {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug              String              @unique
  raw_markdown      String
  publish_date      DateTime?           @db.Date
  section_id        String              @db.Uuid
  created_at        DateTime            @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  content_sections  content_sections    @relation(fields: [section_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  content_tags      content_tags[]
  vector_embeddings vector_embeddings[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model content_sections {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  category        String
  description     String?
  created_at      DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  content_entries content_entries[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model content_tags {
  content_entry_id String          @db.Uuid
  tag_id           String          @db.Uuid
  content_entries  content_entries @relation(fields: [content_entry_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tags             tags            @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([content_entry_id, tag_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tags {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String         @unique
  color_code   String?
  content_tags content_tags[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model vector_embeddings {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text_chunk       String
  embedding_vector Unsupported("vector")
  content_entry_id String                @db.Uuid
  created_at       DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  content_entries  content_entries       @relation(fields: [content_entry_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
